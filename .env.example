# Required: Your Apple Music user token (lasts ~6 months)
# See README.md for how to get this
APPLE_USER_TOKEN=

# Your Apple Music storefront (two-letter country code)
# Examples: us, gb, za, de, jp
APPLE_STOREFRONT=us

# Optional: Dev token is auto-scraped from Apple's web player if not set
# APPLE_DEV_TOKEN=

# Optional: Path to your Obsidian vault's Music folder for listening guides
# If not set, listening guides will be created in ./guides/
OBSIDIAN_MUSIC_PATH=
